[node name="ActiveTitle" type="Label" parent="QuestMargin/QuestVBox/QuestScroll/QuestLists"]
layout_mode = 2
text = "Active"

[node name="ActiveList" type="VBoxContainer" parent="QuestMargin/QuestVBox/QuestScroll/QuestLists"]
layout_mode = 2

[node name="OfferTitle" type="Label" parent="QuestMargin/QuestVBox/QuestScroll/QuestLists"]
layout_mode = 2
