[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/quest_panel.gd" id="1"]

[node name="QuestPanel" type="PanelContainer"]
script = ExtResource("1")

[node name="QuestMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 10

[node name="QuestVBox" type="VBoxContainer" parent="QuestMargin"]
layout_mode = 2

[node name="QuestTitle" type="Label" parent="QuestMargin/QuestVBox"]
