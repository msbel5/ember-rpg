[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/narrative_panel.gd" id="1"]

[node name="NarrativePanel" type="PanelContainer"]
script = ExtResource("1")

[node name="NarrativeMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 10

[node name="NarrativeVBox" type="VBoxContainer" parent="NarrativeMargin"]
layout_mode = 2

[node name="NarrativeTitle" type="Label" parent="NarrativeMargin/NarrativeVBox"]
layout_mode = 2
text = "Narrative"

[node name="NarrativeLog" type="RichTextLabel" parent="NarrativeMargin/NarrativeVBox"]
layout_mode = 2
size_flags_vertical = 3
bbcode_enabled = true
autowrap_mode = 3
scroll_following = false
